# Netlify build-time analytics configuration. Use the same PostHog project
# key and hosts as the ZeroQuarry product deployment so anonymous marketing
# activity is joined to the user after signup on console.zeroquarry.com.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PUBLIC_HOST=https://events.zeroquarry.com
POSTHOG_UI_HOST=https://us.posthog.com
